<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_display"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="8dp" />

    <!-- テーマ切替 -->
    <Button
        android:id="@+id/settingsThemeButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_theme_light"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    <!-- 言語切替 -->
    <Button
        android:id="@+id/settingsLangButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_lang_btn"
        android:layout_marginBottom="24dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_developer"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="8dp" />

    <!-- デバッグログ -->
    <Button
        android:id="@+id/settingsDebugButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Debug Log: OFF ○"
        android:layout_marginBottom="8dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_debug_desc"
        android:textSize="11sp"
        android:textColor="#888888"
        android:fontFamily="monospace" />

</LinearLayout>
